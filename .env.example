# Postgres connection (local defaults)
PGHOST=localhost
PGPORT=5432
PGDATABASE=zertz
PGUSER=postgres
PGPASSWORD=postgres

# API port
PORT=5050

# JWT secret for authentication (change in production!)
JWT_SECRET=zertz-dev-secret-change-me-in-production

# VAPID keys for Web Push notifications (generate with: node -e "import('web-push').then(m => { const k = m.default.generateVAPIDKeys(); console.log(k); })")
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
